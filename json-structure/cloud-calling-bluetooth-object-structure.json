{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/webex/refs/heads/main/json-structure/cloud-calling-bluetooth-object-structure.json",
  "name": "BluetoothObject",
  "description": "BluetoothObject schema from Webex API",
  "type": "object",
  "properties": {
    "enabled": {
      "type": "boolean",
      "example": true,
      "description": "Enable/disable Bluetooth."
    },
    "mode": {
      "type": "string",
      "enum": [
        "PHONE"
      ],
      "description": "Select a Bluetooth mode."
    },
    "PHONE": {
      "type": "string"
    },
    "HANDS_FREE": {
      "type": "string"
    },
    "BOTH": {
      "type": "string"
    }
  },
  "required": [
    "enabled",
    "mode"
  ]
}